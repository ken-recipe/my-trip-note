---
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const imageRegex = /!\[([^\]]*)\]\(([^)]+)\)/g;

const slides: { src: string; alt: string }[] = [];
for (const post of posts) {
  let match;
  while ((match = imageRegex.exec(post.body ?? "")) !== null) {
    const [, alt, src] = match;
    if (src.startsWith("/images/")) {
      slides.push({ src, alt: alt || post.data.title });
    }
  }
}

// シャッフルしてランダム順に表示
for (let i = slides.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [slides[i], slides[j]] = [slides[j], slides[i]];
}
---

<div class="swiper hero-swiper mt-6 mb-2 overflow-hidden rounded-xl">
  <div class="swiper-wrapper">
    {slides.map(slide => (
      <div class="swiper-slide">
        <img
          src={slide.src}
          alt={slide.alt}
          class="h-40 w-full object-cover rounded-lg sm:h-48 md:h-56"
          loading="lazy"
        />
      </div>
    ))}
  </div>
  <div class="swiper-pagination"></div>
  <div class="swiper-button-prev"></div>
  <div class="swiper-button-next"></div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";
  import "swiper/css/pagination";

  document.addEventListener("astro:page-load", () => {
    new Swiper(".hero-swiper", {
      modules: [Navigation, Pagination, Autoplay],
      loop: true,
      slidesPerView: 1.5,
      spaceBetween: 12,
      centeredSlides: true,
      breakpoints: {
        640: { slidesPerView: 2.5, spaceBetween: 16 },
        768: { slidesPerView: 3, spaceBetween: 20 },
      },
      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
      },
      speed: 800,
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
      },
    });
  });
</script>

<style>
  .hero-swiper .swiper-button-prev,
  .hero-swiper .swiper-button-next {
    color: white;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 50%;
    width: 36px;
    height: 36px;
  }

  .hero-swiper .swiper-button-prev::after,
  .hero-swiper .swiper-button-next::after {
    font-size: 14px;
    font-weight: bold;
  }

  .hero-swiper .swiper-pagination-bullet {
    background: white;
    opacity: 0.6;
  }

  .hero-swiper .swiper-pagination-bullet-active {
    opacity: 1;
  }
</style>
