---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
---

<Layout title={`お問い合わせ | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section class="app-prose mb-28 max-w-app">
      <h1 class="text-2xl tracking-wider sm:text-3xl">お問い合わせ</h1>
      <p>
        記事へのご感想・ご質問などお気軽にお送りください。<br />
        通常2〜3営業日以内にご返信いたします。
      </p>

      <form
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        class="mt-8 flex flex-col gap-6 not-prose"
      >
        <div class="flex flex-col gap-1">
          <label for="name" class="text-sm font-medium">お名前</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="山田 太郎"
            class="rounded border border-border bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label for="email" class="text-sm font-medium">メールアドレス</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="example@email.com"
            class="rounded border border-border bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent"
          />
        </div>

        <div class="flex flex-col gap-1">
          <label for="message" class="text-sm font-medium">メッセージ</label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            placeholder="メッセージを入力してください"
            class="rounded border border-border bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="self-start rounded bg-accent px-6 py-2 text-sm font-medium text-background hover:opacity-80 transition-opacity"
        >
          送信する
        </button>
      </form>
    </section>
  </main>
  <Footer />
</Layout>
